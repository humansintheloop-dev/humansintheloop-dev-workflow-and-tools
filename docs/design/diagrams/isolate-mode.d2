direction: left

**.style.font-size: 20

legend: "Claude Code" {
  icon: ../simpler-coding-agent-logo.png
  near: bottom-center
}

Plan: Plan with tasks {
  style.font-size: 24
  task: "" {
    shape: image
    icon: ../plan-task.png
    width: 300
  }
}

Host: Host {
  style.font-size: 24
  direction: down
  branch: "Create idea branch and worktree"
  scaffold: "Run project scaffolding" {
    icon: ../simpler-coding-agent-logo.png
    icon.near: bottom-right
  }
  clone: "Clone worktree"
  branch -> scaffold -> clone
}

VM: "Isolarium VM" {
  style.font-size: 24
  grid-rows: 1
  loop: "Worktree Mode task loop (see Section 4)" {
    icon: ../simpler-coding-agent-logo.png
    icon.near: bottom-right
  }
}

PR: "GitHub Pull Request" {
  style.font-size: 24
  shape: rectangle
}

Plan -> Host
Host -> VM -> PR
