direction: right

**.style.font-size: 40

legend: "Claude Code" {
  icon: ../simpler-coding-agent-logo.png
  near: bottom-center
}

Plan: Plan with tasks {
  style.font-size: 56
  task: "" {
    shape: image
    icon: ../plan-task.png
    width: 300
  }
}

Main: "i2code implement" {
  style.font-size: 56
  direction: down

  Setup: "Setup:" {
    style.font-size: 48
    direction: down
    worktree: "Ensure Git worktree exists"
    recovery: "Commit recovery" {
      icon: ../simpler-coding-agent-logo.png
      icon.near: bottom-right
    }
    push: "Push commits"
    worktree -> recovery -> push

  }

  Loop: "For each incomplete task:" {
    style.font-size: 48
    direction: down
    fix-ci: "Fix CI failures" {
      icon: ../simpler-coding-agent-logo.png
      icon.near: bottom-right
    }
    comments: "Process PR comments" {
      icon: ../simpler-coding-agent-logo.png
      icon.near: bottom-right
    }
    implement: "Implement task and commit" {
      icon: ../simpler-coding-agent-logo.png
      icon.near: bottom-right
    }
    push-pr: "Push / Create PR"
    wait-ci: "Wait for CI"
    fix-ci -> comments -> implement -> push-pr -> wait-ci
  }

  ready: "Mark PR ready"

  Setup -> Loop
  Loop -> ready

}

PR: "GitHub Pull Request" {
  style.font-size: 56
  shape: rectangle
}

Plan -> Main -> PR


PR.left: 2500
PR.top: 1000
PR.near: Main
